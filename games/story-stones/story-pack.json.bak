      "beats": [
        {
          "id": "beginning",
          "narrator": "story-dragon--magic-rock--owl-beginning",
          "text": "At Lavender Cloudberry Bakery, Friendly Dragon saw that the breakfast bell would not ring. With a hopeful smile, Friendly Dragon puffed a bright spark."
        },
        {
          "id": "complication",
          "narrator": "story-dragon--magic-rock--owl-complication",
          "text": "The puzzle grew trickier when a floury breeze crossed the courtyard. Friendly Dragon warmed the air, and Meadow Owl fanned a measured breeze, until they saw a neat loop."
        },
        {
          "id": "resolution",
          "narrator": "story-dragon--magic-rock--owl-resolution",
          "text": "Magic Rock finished the plan and tapped three sparkling beats. Soon, the bell rang three buttery notes. The ovens puffed sweet clouds and the bunting danced."
        }
      ]
