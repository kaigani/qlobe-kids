      "setting": {
        "label": "Amber Moonpetal Garden",
        "backdrop": "assets/backdrops/stories/croissant--magic-rock--orange-cat.webp",
        "alt": "Amber Moonpetal Garden, an open cosy storybook setting.",
        "prompt": "Use case: illustration-story. Asset type: 16:9 Story Stones game backdrop. Primary request: Amber Moonpetal Garden, a moon-flower garden with pale blossoms, shell paths, low hedges, and a spacious circular lawn; amber leaves twinkling at the edges. Style/medium: cosy children's picture-book illustration, hand-painted gouache and coloured-pencil texture on warm paper, chunky charcoal contours, charming imperfect brush marks, matching the approved Story Stones seed 1337 art direction. Composition/framing: wide 16:9 view with a broad uncluttered lower-centre performance clearing and environmental detail around the edges. Lighting/mood: honey-gold light, gentle, magical, welcoming for ages 3–7. Constraints: environment only; preserve a clear floor for three separately composited story-stone sprites. Avoid: characters, creatures, people, food or loose hero objects in the performance area, text, letters, logo, watermark, UI, border, collage, photorealism, 3D.",
        "seed": 1478809463,
        "workflow": "krea2-turbo-t2i",
        "width": 1344,
        "height": 768,
        "steps": 8,
        "cfg": 1
      },
      "beats": [
        {
          "id": "beginning",
          "narrator": "story-croissant--magic-rock--orange-cat-beginning",
          "text": "Orange Cat reached Amber Moonpetal Garden, where the moonpetals would not open. Orange Cat followed tiny paw-marks."
        },
        {
          "id": "complication",
          "narrator": "story-croissant--magic-rock--orange-cat-complication",
          "text": "Then a shy cloud covered the light, and Croissant hurried over. Croissant puffed into a cushion; Orange Cat patted one part into place; soon they had a garden rhythm."
        },
        {
          "id": "resolution",
          "narrator": "story-croissant--magic-rock--orange-cat-resolution",
          "text": "For the final touch, Magic Rock rumbled the pieces into line. At once, the moonpetals opened in a glowing wave. Soft petals swirled above the lawn in a parade."
        }
      ]
    },
