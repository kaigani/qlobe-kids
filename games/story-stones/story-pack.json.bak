        "cfg": 1
      },
      "beats": [
        {
          "id": "beginning",
          "narrator": "story-magic-rock--orange-cat--white-cat-beginning",
          "text": "At Velvet Featherboat Harbour, Orange Cat saw that the featherboats had drifted from their docks. With a hopeful smile, Orange Cat rolled a loose piece back."
        },
        {
          "id": "complication",
          "narrator": "story-magic-rock--orange-cat--white-cat-complication",
          "text": "White Cat brought a new idea, but the harbour breeze changed direction. Orange Cat followed tiny paw-marks, while White Cat balanced on the edge, making a path to shore."
        },
        {
          "id": "resolution",
          "narrator": "story-magic-rock--orange-cat--white-cat-resolution",
          "text": "Magic Rock took a turn and tapped three sparkling beats. Together, all three made sure the boats bobbed beside the quay again. Bright flags rose while water clapped against the steps."
        }
      ]
    },
