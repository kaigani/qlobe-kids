        "width": 1344,
        "height": 768,
        "steps": 8,
        "cfg": 1
      },
      "beats": [
        {
          "id": "beginning",
          "narrator": "story-magic-rock--treasure-chest--wishing-star-beginning",
          "text": "Puddle Woolly Mountain Station was ready for a lovely day, but the cloud train could not find the station. Magic Rock became flat and steady."
        },
        {
          "id": "complication",
          "narrator": "story-magic-rock--treasure-chest--wishing-star-complication",
          "text": "Treasure Chest brought a new idea, but woolly fog covered the platform. Magic Rock tapped three sparkling beats, while Treasure Chest shone light across the ground, making a clear signal."
        },
        {
          "id": "resolution",
          "narrator": "story-magic-rock--treasure-chest--wishing-star-resolution",
          "text": "Wishing Star finished the plan and twinkled a good idea. Soon, the cloud train reached the platform. Mountain flags bobbed as the station clock chimed hooray."
        }
      ]
